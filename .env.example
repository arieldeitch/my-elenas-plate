# Supabase — copy to `.env` and fill in from your Supabase project
# (Project Settings → API). Only the anon (public) key belongs in the client.
# NEVER put the service_role key here or anywhere in the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# When both are empty/unset the app runs in local demo mode (localStorage only).
